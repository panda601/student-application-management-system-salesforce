        <field>Student__c.Phone__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>Student__c.Age__c</field>
        <readable>true</readable>
    </fieldPermissions>


    <fieldPermissions>
        <editable>true</editable>
        <field>Student__c.Address__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>Student__c.Student_ID__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Permissions - Application__c -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Application__c.Application_Number__c</field>
        <readable>true</readable>
    </fieldPermissions>





    <fieldPermissions>
        <editable>true</editable>
        <field>Application__c.Comments__c</field>
