<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>false</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <nextAutomatedApprover>
        <useApproverFieldOfRecordOwner>false</useApproverFieldOfRecordOwner>
        <userHierarchyField>Manager</userHierarchyField>
    </nextAutomatedApprover>
    <approvalPageFields>
        <field>Name</field>
        <field>Student__c</field>
        <field>Course__c</field>
        <field>Intake__c</field>
        <field>Status__c</field>
        <field>Total_Payments__c</field>
        <field>Outstanding_Balance__c</field>
    </approvalPageFields>
    <approvalStep>
        <assignedApprover>
            <approver>
                <name>Manager</name>
                <type>userHierarchyField</type>
            </approver>
        </assignedApprover>
        <label>Manager Evaluation</label>
        <name>Manager_Evaluation</name>
    </approvalStep>
    <entryCriteria>
        <formula>ISPICKVAL(Status__c, 'In Review') &amp;&amp; Total_Payments__c &gt; 0</formula>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>Update_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>false</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>Update_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_Status_InReview</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Application Approval Process</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOnly</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
