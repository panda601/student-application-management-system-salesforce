<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Total_Payments_NonNegative</fullName>
    <active>true</active>
    <description>Ensure Total Payments is non‑negative</description>
    <errorConditionFormula>Total_Payments__c &lt; 0</errorConditionFormula>
    <errorMessage>Total Payments must be greater than or equal to zero.</errorMessage>
</ValidationRule>
