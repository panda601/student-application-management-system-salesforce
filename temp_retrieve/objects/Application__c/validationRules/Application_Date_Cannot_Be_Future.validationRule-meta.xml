<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Application_Date_Cannot_Be_Future</fullName>
    <active>true</active>
    <description>Ensures the Application Date is not in the future.</description>
    <errorConditionFormula>Application_Date__c &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Application_Date__c</errorDisplayField>
    <errorMessage>Application Date cannot be a future date.</errorMessage>
</ValidationRule>
